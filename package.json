{
  "name": "colonna",
  "version": "1.0.0",
  "description": "Калькулятор стальных колонн промышленных зданий по СП 16.13330 / СП 20.13330",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs run --pool=threads --maxWorkers=1 --minWorkers=1 --no-file-parallelism",
    "verify": "npm run typecheck && npm test && npm run build",
    "typecheck": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc --noEmit",
    "typecheck:scripts": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.scripts.json",
    "lint": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc --noEmit",
    "verify:columns:baseline": "python scripts/verify_baseline.py",
    "verify:columns:compare": "python scripts/compare_scenarios.py",
    "verify:purlin": "tsx scripts/verify_purlin.ts",
    "verify:truss": "tsx scripts/verify_truss.ts",
    "verify:all": "npm run typecheck && npm run typecheck:scripts && npm run verify:columns:baseline && npm run verify:purlin && npm run verify:truss"
  },
  "dependencies": {
    "hyperformula": "^3.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "tsx": "^4.20.6",
    "typescript": "^5.4.0",
    "vite": "^5.3.0",
    "vitest": "^3.2.4"
  }
}
